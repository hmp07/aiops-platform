# Database
DATABASE_URL=postgresql+asyncpg://aiops:aiops@localhost:5432/aiops
DATABASE_SYNC_URL=postgresql://aiops:aiops@localhost:5432/aiops

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CELERY_BROKER_URL=redis://localhost:6379/1
REDIS_CELERY_RESULT_URL=redis://localhost:6379/2

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# JWT
JWT_SECRET_KEY=change-me-in-production-use-random-string
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# LLM (Anthropic)
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# External Systems (fill in when ready)
ITOP_API_URL=
ITOP_API_USER=
ITOP_API_PASSWORD=
ZABBIX_API_URL=
ZABBIX_API_USER=
ZABBIX_API_PASSWORD=
SIGNOZ_API_URL=
SIGNOZ_API_KEY=

# Notification
WECOM_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# App
DEBUG=true
